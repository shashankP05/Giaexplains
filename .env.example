# Template only — DO NOT put real values here (this file is committed to git).
# Put real values in a file named ".env" (gitignored) for local use,
# and in Vercel → Project → Settings → Environment Variables for production.

# From Brevo → SMTP & API → SMTP tab
BREVO_SMTP_USER=
BREVO_SMTP_KEY=

# Where leads are delivered and who they appear to come from.
# MAIL_FROM must be a sender/domain you have verified in Brevo.
MAIL_TO=
MAIL_FROM=
