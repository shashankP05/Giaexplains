# Copy these into Vercel → Project → Settings → Environment Variables.
# Do NOT commit real values. This file is only a template.

# From Brevo → SMTP & API → SMTP tab
BREVO_SMTP_USER=your-brevo-login@example.com
BREVO_SMTP_KEY=xsmtpsib-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Where leads are delivered and who they appear to come from.
# MAIL_FROM must be a sender/domain you have verified in Brevo.
MAIL_TO=hi@giaexplains.com
MAIL_FROM=hi@giaexplains.com
